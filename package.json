{
  "name": "auditbase",
  "version": "1.0.0",
  "description": "AuditBase Dashboard",
  "scripts": {
    "start": "concurrently \"npm run serve\" \"npm run bridge\" \"npm run ollama\"",
    "serve": "python3 -m http.server 8000",
    "bridge": "cd mcp-bridge && node server.js",
    "ollama": "ollama serve 2>/dev/null || /Applications/Ollama.app/Contents/Resources/ollama serve"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
